<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Human Clinic SP — Mapa Mental de Marketing</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    background: #f8f7f4;
    color: #1a1a1a;
    min-height: 100vh;
  }

  header {
    background: #fff;
    border-bottom: 0.5px solid #d3d1c7;
    padding: 18px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-left h1 {
    font-size: 17px;
    font-weight: 600;
    color: #1A5FA8;
    letter-spacing: -0.01em;
  }

  .header-left p {
    font-size: 12px;
    color: #888780;
    margin-top: 2px;
  }

  .legend {
    display: flex;
    gap: 18px;
    align-items: center;
    flex-wrap: wrap;
  }

  .leg {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #5f5e5a;
  }

  .leg-dot {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .map-container {
    padding: 32px 24px 60px;
    overflow-x: auto;
  }

  svg.mindmap {
    display: block;
    margin: 0 auto;
    max-width: 1200px;
    width: 100%;
    overflow: visible;
  }

  .node {
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .node:hover > rect,
  .node:hover > ellipse,
  .node:hover > circle {
    opacity: 0.82;
  }

  /* tooltip */
  #tooltip {
    position: fixed;
    background: #fff;
    border: 0.5px solid #d3d1c7;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 12px;
    color: #5f5e5a;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    max-width: 220px;
    line-height: 1.5;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  /* panel */
  #panel {
    position: fixed;
    right: 0; top: 0; bottom: 0;
    width: 340px;
    background: #fff;
    border-left: 0.5px solid #d3d1c7;
    padding: 24px 24px 32px;
    transform: translateX(100%);
    transition: transform 0.25s cubic-bezier(.4,0,.2,1);
    z-index: 50;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #panel.open { transform: translateX(0); }

  #panel-close {
    position: absolute;
    top: 16px; right: 16px;
    background: none;
    border: 0.5px solid #d3d1c7;
    border-radius: 6px;
    width: 28px; height: 28px;
    cursor: pointer;
    font-size: 14px;
    color: #888780;
    display: flex; align-items: center; justify-content: center;
  }

  #panel-close:hover { background: #f1efe8; }

  #panel-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    width: fit-content;
  }

  #panel-title {
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.3;
  }

  #panel-body {
    font-size: 14px;
    color: #5f5e5a;
    line-height: 1.7;
  }

  #panel-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  #panel-items li {
    font-size: 13px;
    color: #3d3d3a;
    padding: 7px 10px;
    background: #f8f7f4;
    border-radius: 6px;
    border-left: 2px solid #d3d1c7;
    line-height: 1.5;
  }

  .kpi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .kpi-card {
    background: #f1efe8;
    border-radius: 8px;
    padding: 10px 12px;
  }

  .kpi-label { font-size: 11px; color: #888780; }
  .kpi-value { font-size: 18px; font-weight: 600; color: #1A5FA8; margin-top: 2px; }

  @media (max-width: 600px) {
    #panel { width: 100%; }
    header { padding: 12px 16px; flex-direction: column; gap: 10px; align-items: flex-start; }
  }
</style>
</head>
